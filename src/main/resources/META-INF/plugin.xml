<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.github.micahhauge.modulithnavigator</id>
    <name>Modulith Navigator</name>
    <vendor url="https://github.com/micahhauge">micahhauge</vendor>
    <description><![CDATA[
        IntelliJ Project view plugin for Spring Modulith that sorts modules by type,
        open first and internal second, so your architecture is visible without opening a single file.
        <br/><br/>
        A module is considered <b>internal</b> if its only subdirectory is named <code>internal</code>.
        All other modules are treated as <b>open</b> and sorted to the top.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <treeStructureProvider
            implementation="com.github.micahhauge.modulithnavigator.ModulithTreeStructureProvider"/>
        <applicationService
            serviceImplementation="com.github.micahhauge.modulithnavigator.ModulithNavigatorSettings"/>
        <applicationConfigurable
            parentId="tools"
            instance="com.github.micahhauge.modulithnavigator.ModulithNavigatorConfigurable"
            id="com.github.micahhauge.modulithnavigator.ModulithNavigatorConfigurable"
            displayName="Modulith Navigator"/>
    </extensions>
</idea-plugin>
